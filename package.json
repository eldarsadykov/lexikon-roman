{
  "name": "lexikon-roman",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:route-rules": "bun run ./pug-to-md/redirects.ts",
    "preinstall": "bun run generate:route-rules",
    "predev": "bun run generate:content && bun run generate:route-rules",
    "prebuild": "bun run generate:content && bun run generate:route-rules",
    "pretypecheck": "bun run generate:content && bun run generate:route-rules",
    "pregenerate": "bun run generate:content && bun run generate:route-rules",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "dev": "nuxt dev --host",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "typecheck": "nuxt typecheck",
    "generate:content": "bun run ./pug-to-md/index.ts && bun run format:html",
    "format:html": "prettier --ignore-path .prettierignore --write \"pug-to-md/generated/html/**/*.html\"",
    "format:html:check": "prettier --ignore-path .prettierignore --check \"pug-to-md/generated/html/**/*.html\"",
    "test": "vitest"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.94",
    "@iconify-json/simple-icons": "^1.2.71",
    "@iconify-json/vscode-icons": "^1.2.44",
    "@nuxt/content": "^3.11.2",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.5.0",
    "@nuxtjs/mdc": "^0.20.1",
    "@puresignal/essl": "^0.1.1",
    "@puresignal/fetch-stream-audio": "^0.1.0",
    "@types/audioworklet": "^0.0.96",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vueuse/core": "^14.2.1",
    "better-sqlite3": "^12.8.0",
    "minimark": "^0.2.0",
    "nuxt": "^4.3.1",
    "nuxt-llms": "0.2.0",
    "nuxt-og-image": "^5.1.13",
    "tailwindcss": "^4.2.1",
    "ufo": "^1.6.3",
    "unist-util-visit": "^5.1.0",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@types/bun": "^1.3.9",
    "@types/node": "^25.3.2",
    "@types/pug": "^2.0.10",
    "@types/turndown": "^5.0.6",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "pug": "^3.0.3",
    "turndown": "^7.2.2",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.5"
  }
}
